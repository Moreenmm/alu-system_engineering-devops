#!/usr/bin/env bash
# SSH client configuration
# Configured to use the private key /keys
# Configured to refuse password authentication

Include /etc/ssh/ssh_config.d/*.conf

# Public server connection (use when outside your private network)
Host myserver-public
    HostName 44.211.255.175
    User ubuntu
    IdentityFile /keys.pub
    PasswordAuthentication no

# Private server connection (use when inside the same private network/VPC)
Host myserver-private
    HostName 44.211.255.175
    User ubuntu
    IdentityFile keys
    PasswordAuthentication no

# public key
ssh-rsa  m.murugi@alustudent.com
